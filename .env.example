# OpenPaw Graveyard Hack - Environment Variables
# Copy this to .env and fill in your keys

# Tapestry Protocol (get from app.usetapestry.dev)
TAPESTRY_API_KEY=

# Bankr Crypto Trading (get from bankr.bot/api)
BANKR_API_KEY=

# Moltbook AI Social (get from moltbook.com)
MOLTBOOK_API_KEY=

# Brave Search API (get from brave.com/search/api — free tier ~1000/month)
BRAVE_API_KEY=

# Helius Solana RPC (get from helius.dev — free tier)
HELIUS_RPC_URL=

# Ollama local LLM (optional — falls back to templates)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Jupiter API key (get from jup.ag/api — Basic tier free, 600 req/min)
JUPITER_API_KEY=
# Flash loan scanner (optional overrides)
# FLASH_MIN_PROFIT_BPS=5
# FLASH_SCAN_INTERVAL=30
# FLASH_POST_THRESHOLD_BPS=3
